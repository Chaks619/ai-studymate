PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Set to "false" to exercise the CRUD endpoints without spending Gemini calls.
# Conversations are then created with the user's message but no AI reply, and
# POST /conversations/:id/messages returns 503.
ENABLE_AI=true
